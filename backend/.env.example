# Django
DEBUG=True
SECRET_KEY=replace-with-a-long-random-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# SQLite (local dev) — leave DB_ENGINE unset or set to "sqlite3"
# DB_ENGINE=sqlite3

# Azure SQL (staging/prod)
DB_ENGINE=mssql
DB_NAME=your-database-name
DB_USER=your-db-user@your-server
DB_PASSWORD=your-db-password
DB_HOST=your-server.database.windows.net
DB_PORT=1433
DB_DRIVER=ODBC Driver 18 for SQL Server

# Firebase
# Local dev — point at the JSON file (relative to backend/ or absolute)
FIREBASE_CREDENTIALS_PATH=../certs/firebase-adminsdk.json
# Production / containers — full JSON content, optionally base64-encoded
# Generate with: base64 -w 0 certs/firebase-adminsdk.json
FIREBASE_CREDENTIALS_JSON=""

# Azure Blob Storage
AZURE_ACCOUNT_NAME=your-storage-account-name
AZURE_ACCOUNT_KEY=your-storage-account-key
AZURE_CONTAINER_PUBLIC=public
AZURE_CONTAINER_PRIVATE=private

# Agora (video calls)
AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-app-certificate

# SEPay (payments)
SEPAY_MERCHANT_ID=your-sepay-merchant-id
SEPAY_MERCHANT_SECRET_KEY=your-sepay-merchant-secret-key

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000
